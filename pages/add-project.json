    {
      "name": "saveProject",
      "description": "",
      "type": "method",
      "body": "if (!$ctrl.newProjectName) return;\nvar id = $ctrl.newProjectName.toLowerCase().replace(/\\s+/g, '-') + '-' + Date.now();\nvar stored = localStorage.getItem('pm_projects');\nvar projects = stored ? JSON.parse(stored) : [];\nprojects.push({id: id, name: $ctrl.newProjectName, description: $ctrl.newProjectDesc});\nlocalStorage.setItem('pm_projects', JSON.stringify(projects));\n$ctrl.$state.go('home.project', {projectId: id}, {reload: 'home'});",
