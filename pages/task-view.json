{
  "name": "task-view",
  "type": "page",
  "url": "/projects/:projectId/tasks/:taskId/view",
  "params": {
    "projectId": "",
    "taskId": ""
  },
  "variables": [
    {
      "name": "$state",
      "type": "service"
    },
    {
      "name": "$timeout",
      "type": "service"
    },
    {
      "name": "task",
      "description": "Loads the specific task's data from localStorage.",
      "type": "property",
      "value": "(function() { var tasks = JSON.parse(localStorage.getItem('pm_tasks_' + $ctrl.pageParameters.projectId) || '[]'); return tasks.find(function(t) { return t.id === $ctrl.pageParameters.taskId; }) || {id: $ctrl.pageParameters.taskId, title: 'Task Not Found', description: 'No description available.', status: 'Unknown'}; })()"
    },
    {
      "name": "comments",
      "description": "List of comments for the current task, loaded from mock data or with a default if none exist. Comments are stored in localStorage, nested by projectId and taskId.",
      "type": "property",
      "value": "(function() {\n  var projectId = $ctrl.pageParameters.projectId;\n  var taskId = $ctrl.pageParameters.taskId;\n\n  var mockCommentsData = {\n    'api-integration-gateway': {\n      'rate-limiting': [\n        { id: 'c1', author: 'DevOps Team', text: 'We should consider using a Redis-based solution for distributed rate limiting across all gateway instances.', timestamp: '2023-10-26T10:00:00Z' },\n        { id: 'c2', author: 'Jane Smith (Product)', text: 'What are the proposed default limits? We need to ensure legitimate high-volume users are not blocked.', timestamp: '2023-10-26T10:30:00Z' }\n      ]\n    },\n    'frontend-performance-opt': {\n      'image-optimization': [\n        { id: 'c11', author: 'Senior Frontend Dev', text: 'Let\\'s use Squoosh.app as a baseline for the compression quality we should aim for.' },\n        { id: 'c12', author: 'UX Designer', text: 'Please ensure that lazy-loaded images have a placeholder to prevent layout shifts. A blurred, low-res version would be ideal.' }\n      ]\n    },\n    'gdpr-compliance-audit': {\n      'data-mapping': [\n        { id: 'c13', author: 'Legal Team', text: 'Please make sure to include cookies and other tracking technologies in the data mapping exercise. This is a common point of failure in GDPR audits.' },\n        { id: 'c14', author: 'Engineering Lead', text: 'We will need access to the production database logs to accurately map all data access patterns. Please provision read-only access for the audit team.' }\n      ]\n    }\n  };\n\n  var allCommentsKey = 'pm_all_comments';\n  var allComments = JSON.parse(localStorage.getItem(allCommentsKey) || '{}');\n  var needsUpdate = false;\n\n  // Ensure mock data is present in localStorage for other tasks if not already there\n  for (var pId in mockCommentsData) {\n    if (!allComments[pId]) {\n      allComments[pId] = {};\n    }\n    for (var tId in mockCommentsData[pId]) {\n      if (!allComments[pId][tId]) {\n        allComments[pId][tId] = mockCommentsData[pId][tId];\n        needsUpdate = true;\n      }\n    }\n  }\n\n  // Check if comments exist for the current task, if not, add a default conversation\n  if (!allComments[projectId]) {\n    allComments[projectId] = {};\n  }\n\n  if (!allComments[projectId][taskId] || allComments[projectId][taskId].length === 0) {\n    var now = new Date().toISOString();\n    allComments[projectId][taskId] = [\n      { id: 'default-comment-alice', author: 'Alice (Project Manager)', text: 'I\\'ve created this task to track the new feature development. Let\\'s use this space for all related discussions.', timestamp: now },\n      { id: 'default-comment-bob', author: 'Bob (Lead Developer)', text: 'Thanks, Alice. I\\'ve reviewed the requirements. I\\'ll be pushing the initial boilerplate code to a new branch by EOD.', timestamp: now },\n      { id: 'default-comment-charlie', author: 'Charlie (QA Engineer)', text: 'Sounds good. I\\'ll start drafting the test plan based on the requirements doc.', timestamp: now }\n    ];\n    needsUpdate = true;\n  }\n\n  if (needsUpdate) {\n    localStorage.setItem(allCommentsKey, JSON.stringify(allComments));\n  }\n\n  return allComments[projectId][taskId];\n})()"
    },
    {
      "name": "newCommentText",
      "description": "Text for the new comment input.",
      "type": "property",
      "value": "''"
    },
    {
      "name": "newCommentAuthor",
      "description": "Author for the new comment input.",
      "type": "property",
      "value": "''"
    },
    {
      "name": "addComment",
      "description": "Adds a new comment to the list and saves to localStorage.",
      "type": "method",
      "body": "if (!$ctrl.newCommentText || !$ctrl.newCommentAuthor) return; var projectId = $ctrl.pageParameters.projectId; var taskId = $ctrl.pageParameters.taskId; var newComment = { id: 'c-' + Date.now(), author: $ctrl.newCommentAuthor, text: $ctrl.newCommentText, timestamp: new Date().toISOString() }; $ctrl.comments.push(newComment); var allComments = JSON.parse(localStorage.getItem('pm_all_comments') || '{}'); if (!allComments[projectId]) { allComments[projectId] = {}; } allComments[projectId][taskId] = $ctrl.comments; localStorage.setItem('pm_all_comments', JSON.stringify(allComments)); $ctrl.newCommentText = ''; $ctrl.newCommentAuthor = '';",
      "invokeOnLoad": false,
      "isAsync": false,
      "returnType": {
        "name": "any"
      },
      "parameters": [],
      "watch": []
    },
    {
      "name": "deleteComment",
      "description": "Deletes a comment from the list and saves to localStorage.",
      "type": "method",
      "body": "var projectId = $ctrl.pageParameters.projectId; var taskId = $ctrl.pageParameters.taskId; $ctrl.comments = $ctrl.comments.filter(function(c) { return c.id !== commentId; }); var allComments = JSON.parse(localStorage.getItem('pm_all_comments') || '{}'); if (!allComments[projectId]) { allComments[projectId] = {}; } allComments[projectId][taskId] = $ctrl.comments; localStorage.setItem('pm_all_comments', JSON.stringify(allComments));",
      "invokeOnLoad": false,
      "isAsync": false,
      "returnType": {
        "name": "any"
      },
      "parameters": [
        "commentId"
      ],
      "watch": []
    }
