{
  "name": "project",
  "type": "page",
  "url": "/projects/:projectId",
  "params": {
    "projectId": ""
  },
  "variables": [
    {
      "name": "$state",
      "type": "service"
    },
    {
      "name": "tasks",
      "description": "List of tasks for the current project. Loads from localStorage or uses default tasks if none exist.",
      "type": "property",
      "value": "(function() {\n  var currentProjectId = $ctrl.pageParameters.projectId;\n  var localStorageKey = 'pm_tasks_' + currentProjectId;\n  var storedTasks = localStorage.getItem(localStorageKey);\n\n  if (storedTasks) {\n    return JSON.parse(storedTasks);\n  } else {\n    var defaultTasks = [\n      { id: 'task-1', title: 'Task 1: Project Kick-off and Requirement Gathering', description: 'Hold a project kick-off meeting with all stakeholders. Define project scope, objectives, and deliverables. Gather detailed requirements and document them in the project workspace.', status: 'To Do' },\n      { id: 'task-2', title: 'Task 2: UI/UX Design and Prototyping', description: 'Create wireframes and mockups for the main user flows. Develop an interactive prototype and conduct a usability testing session to gather feedback. Iterate on the designs based on feedback.', status: 'To Do' },\n      { id: 'task-3', title: 'Task 3: Backend Development and API Integration', description: 'Set up the database schema and develop the necessary API endpoints. Integrate with third-party services as required. Ensure all endpoints are documented and tested.', status: 'To Do' }\n    ];\n    localStorage.setItem(localStorageKey, JSON.stringify(defaultTasks));\n    return defaultTasks;\n  }\n})()"
    },
    {
      "name": "newTaskTitle",
      "description": "",
      "type": "property",
      "value": "''"
    },
    {
      "name": "newTaskDesc",
      "description": "",
      "type": "property",
      "value": "''"
    },
    {
      "name": "addTask",
      "description": "",
      "type": "method",
      "body": "if (!$ctrl.newTaskTitle) return; $ctrl.tasks.push({id: 't-' + Date.now(), title: $ctrl.newTaskTitle, description: $ctrl.newTaskDesc, status: 'To Do'}); localStorage.setItem('pm_tasks_' + $ctrl.pageParameters.projectId, JSON.stringify($ctrl.tasks)); $ctrl.newTaskTitle = ''; $ctrl.newTaskDesc = '';",
      "invokeOnLoad": false,
      "isAsync": false,
      "returnType": {
        "name": "any"
      },
      "parameters": [],
      "watch": []
    },
    {
      "name": "deleteTask",
      "description": "",
      "type": "method",
      "body": "$ctrl.tasks = $ctrl.tasks.filter(function(t) { return t.id !== taskId; }); localStorage.setItem('pm_tasks_' + $ctrl.pageParameters.projectId, JSON.stringify($ctrl.tasks));",
      "invokeOnLoad": false,
      "isAsync": false,
      "returnType": {
        "name": "any"
      },
      "parameters": [
        "taskId"
      ],
      "watch": []
    }
