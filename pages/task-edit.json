{
  "name": "task-edit",
  "type": "page",
  "url": "/projects/:projectId/tasks/:taskId/edit",
  "params": {
    "projectId": "",
    "taskId": ""
  },
  "variables": [
    {
      "name": "$state",
      "type": "service"
    },
    {
      "name": "task",
      "description": "Loads the specific task's data from localStorage.",
      "type": "property",
      "value": "(function() { var tasks = JSON.parse(localStorage.getItem('pm_tasks_' + $ctrl.pageParameters.projectId) || '[]'); return tasks.find(function(t) { return t.id === $ctrl.pageParameters.taskId; }) || {id: $ctrl.pageParameters.taskId, title: '', description: '', status: 'To Do'}; })()"
    },
    {
      "name": "saveTask",
      "description": "Saves the task data to localStorage and navigates back to the task details page.",
      "type": "method",
      "body": "var projectId = $ctrl.pageParameters.projectId;\nvar taskId = $ctrl.pageParameters.taskId;\nvar tasks = JSON.parse(localStorage.getItem('pm_tasks_' + projectId) || '[]');\nvar taskIndex = tasks.findIndex(function(t) { return t.id === taskId; });\nif (taskIndex !== -1) {\n  tasks[taskIndex] = $ctrl.task;\n} else {\n  tasks.push($ctrl.task);\n}\nlocalStorage.setItem('pm_tasks_' + projectId, JSON.stringify(tasks));\n$ctrl.$state.go('home.task-view', { projectId: projectId, taskId: $ctrl.task.id });",
      "invokeOnLoad": false,
      "isAsync": false,
      "returnType": {
        "name": "any"
      },
      "parameters": [],
      "watch": []
    }
  ],
